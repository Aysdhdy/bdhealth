<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>曼秀雷敦润唇膏真假辨别 - 百家号</title>
    <style>
        /* 全局样式重置 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", Arial, sans-serif;
        }

        /* 页面主体容器 */
        .container {
            width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background-color: #fff;
        }

        /* 百家号头部导航简化样式 */
        .bjh-header {
            height: 60px;
            line-height: 60px;
            background-color: #2c3e50;
            color: #fff;
            padding: 0 20px;
            margin-bottom: 20px;
        }

        .bjh-header h1 {
            font-size: 20px;
            font-weight: normal;
            display: inline-block;
        }

        /* 文章作者信息栏 */
        .author-info {
            display: flex;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid #eee;
            margin-bottom: 20px;
        }

        .author-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: #ddd;
            margin-right: 15px;
            overflow: hidden;
        }

        .author-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .author-detail {
            flex: 1;
        }

        .author-id {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }

        .publish-time {
            font-size: 12px;
            color: #999;
        }

        /* 文章内容区域 */
        .article-content {
            font-size: 16px;
            line-height: 1.8;
            color: #333;
            margin-bottom: 30px;
        }

        .article-content p {
            margin-bottom: 15px;
        }

        /* 图片容器 - 缩略图样式 */
        .img-group {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin: 20px 0;
        }

        .img-item {
            width: 200px;
            height: 200px;
            cursor: pointer;
            overflow: hidden;
            border: 1px solid #eee;
        }

        .img-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .img-item:hover img {
            transform: scale(1.05);
        }

        /* 图片放大模态框 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            max-width: 90%;
            max-height: 90%;
        }

        .modal-content img {
            width: auto;
            height: auto;
            max-width: 100%;
            max-height: 100%;
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 30px;
            color: #fff;
            font-size: 40px;
            font-weight: bold;
            cursor: pointer;
        }

        /* 评论区样式 */
        .comment-section {
            margin-top: 40px;
            border-top: 1px solid #eee;
            padding-top: 30px;
        }

        .comment-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #333;
        }

        .comment-item {
            padding: 15px 0;
            border-bottom: 1px solid #f5f5f5;
        }

        .comment-user {
            font-size: 14px;
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }

        .comment-time {
            font-size: 12px;
            color: #999;
            margin-left: 10px;
        }

        .comment-content {
            font-size: 14px;
            color: #666;
            line-height: 1.6;
        }

        .no-more-comment {
            font-size: 14px;
            color: #999;
            text-align: center;
            padding: 20px 0;
        }
    </style>
</head>
<body>
    <!-- 百家号头部 -->
